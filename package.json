  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
