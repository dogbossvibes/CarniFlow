    "expo-task-manager": "~14.0.9",
    "expo-video": "~3.0.16",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.10",
    "jest-expo": "~54.0.17",
    "nativewind": "^4.2.4",
