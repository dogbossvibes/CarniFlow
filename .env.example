EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ANYVO CONNECT (Community-Bereich). Standard: aus.
# "true" blendet den CONNECT-Tab ein und aktiviert die CONNECT-Screens.
# Solange nicht "true": kein Tab, keine CONNECT-Initialisierung/-Abfragen beim App-Start.
EXPO_PUBLIC_FEATURE_CONNECT_ENABLED=false
