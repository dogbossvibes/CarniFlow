{
  "expo": {
    "name": "ANYVO",
    "slug": "anyvo",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "anyvo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.anyvo.app",
      "buildNumber": "27",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationTemporaryUsageDescriptionDictionary": {
          "TrackingDogSportPrecision": "Anyvo benötigt präzisen Standort, um Fährten und Gegenstände möglichst genau aufzuzeichnen."
        }
      }
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#09090F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anyvo.app",
      "versionCode": 27,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCriuMb0ZKmtn52yNH7AjmfGWsaUEuNDdg"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Anyvo nutzt deinen Standort, um Fährten und Trainingswege während der aktiven Aufnahme aufzuzeichnen.",
          "locationAlwaysAndWhenInUsePermission": "Anyvo kann deinen Standort während einer aktiven Fährtenaufnahme weiter erfassen, auch wenn die App kurz im Hintergrund ist.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ANYVO benötigt Zugriff auf deine Fotos, um Trainingsfotos und Hundefotos hinzuzufügen."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "ANYVO benötigt Zugriff auf dein Mikrofon für Sprachnotizen beim Training."
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false,
          "supportsPictureInPicture": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F1115"
        }
      ],
      "expo-notifications",
      "expo-apple-authentication",
      "expo-font",
      "@sentry/react-native",
      "expo-asset",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "central"
          ],
          "bluetoothAlwaysPermission": "ANYVO nutzt Bluetooth, um externe GPS-Empfänger für die Fährten-Aufzeichnung zu koppeln."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "ANYVO fügt deine Trainingstermine zu deinem Kalender hinzu."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "speechRecognitionPermission": "ANYVO nutzt Spracherkennung für Sprachbefehle im Fährtenmodus.",
          "microphonePermission": "ANYVO benötigt das Mikrofon für Sprachmemos und Sprachbefehle."
        }
      ],
      "expo-sqlite",
      "expo-live-activity",
      "@react-native-community/datetimepicker",
      [
        "expo-local-authentication",
        { "faceIDPermission": "ANYVO nutzt Face ID, um die App zu entsperren." }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e6475526-66fa-42fa-b2a4-e11afc349e7a"
      }
    },
    "owner": "dog.boss.vibes",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
