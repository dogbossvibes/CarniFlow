{
  "expo": {
    "name": "ANYVO",
    "slug": "anyvo",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "anyvo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.anyvo.app",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#09090F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anyvo.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ANYVO nutzt deinen Standort für die Fährten-Aufzeichnung sowie um Trainingsort und Wetter automatisch einzutragen.",
          "locationAlwaysAndWhenInUsePermission": "ANYVO nutzt deinen Standort im Hintergrund, um die Fährten-Aufzeichnung bei gesperrtem Display fortzusetzen.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ANYVO benötigt Zugriff auf deine Fotos, um Trainingsfotos und Hundefotos hinzuzufügen."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "ANYVO benötigt Zugriff auf dein Mikrofon für Sprachnotizen beim Training."
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false,
          "supportsPictureInPicture": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F1115"
        }
      ],
      "expo-notifications",
      "expo-apple-authentication",
      "expo-font",
      "@sentry/react-native",
      "expo-asset",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["central"],
          "bluetoothAlwaysPermission": "ANYVO nutzt Bluetooth, um externe GPS-Empfänger für die Fährten-Aufzeichnung zu koppeln."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e6475526-66fa-42fa-b2a4-e11afc349e7a"
      }
    },
    "owner": "dog.boss.vibes",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
